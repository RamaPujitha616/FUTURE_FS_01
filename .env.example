# Copy this file to .env and fill in your EmailJS values.
# Then restart the dev server (npm run dev).

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Specify who should receive contact messages. This must match a variable in your EmailJS template (e.g. {{to_email}}).
VITE_EMAILJS_TO_EMAIL=ramapujitha.a616@gmail.com
